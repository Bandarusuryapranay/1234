# ── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/smarthire_db"

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-min-32-chars-long-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-long"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ─────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
CLIENT_URL="http://localhost:3000"

# ── Groq (FREE — get key at console.groq.com) ─────────────────
GROQ_API_KEY="gsk_..."

# ── Judge0 self-hosted (FREE — run via Docker) ─────────────────
# docker run -d -p 2358:2358 judge0/judge0-ce:latest
JUDGE0_API_URL="http://localhost:2358"
JUDGE0_API_KEY=""

# ── Microsoft Graph API (Email) ────────────────────────────────
AZURE_TENANT_ID="your-tenant-id"
AZURE_CLIENT_ID="your-client-id"
AZURE_CLIENT_SECRET="your-client-secret"
GRAPH_SENDER_EMAIL="noreply@yourcompany.com"

# NOTE: No Redis needed — background jobs run in-process
